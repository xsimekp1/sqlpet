# Exclude other apps in monorepo
apps/api/
apps/web/

# Exclude root-level files that aren't needed for mobile build
*.zip
*.pdf
animals/
dog_symbols_icons_alpha01_sliced/
cat_symbols_icons_alpha01_sliced/
*.png
!apps/mobile/**/*.png

# Exclude infrastructure and seed files
infra/
seed/

# Exclude caches and temp files
**/__pycache__/
**/.pytest_cache/
**/.ruff_cache/
**/.venv/
**/venv/
**/.env
**/.env.*
!apps/mobile/.env*

# Exclude IDE and editor files
.vscode/
.idea/
.claude/

# Exclude packages that mobile doesn't need
packages/

# Exclude docs and misc
*.md
!apps/mobile/README.md
